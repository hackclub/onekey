# Drizzle
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# Hack Club Auth
HCA_CLIENT_ID=""
HCA_CLIENT_SECRET=""
HCA_REDIRECT_URI=""

# Slack (needs users:read scope)
SLACK_BOT_TOKEN=""

# Token encryption key for AES-256-GCM (generate with: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=""

# Hackatime OAuth
HACKATIME_CLIENT_ID=""
HACKATIME_CLIENT_SECRET=""
# Optional: defaults to {origin}/auth/hackatime/callback
HACKATIME_REDIRECT_URI=""

# Space-separated HCA sub (ident! tag) IDs
ADMIN_IDS=""
REVIEWER_IDS=""

# Hack Club CDN (https://cdn.hackclub.com)
CDN_API_KEY=""

# Staging mode: when "true"/"1"/"yes", skips writes to external systems (e.g. Airtable)
# so a non-prod instance can't leak test data into real records.
STAGING=""